{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "inputs": [
        {
            "id": "configuration",
            "type": "pickString",
            "description": "Select configuration",
            "options": [
                "Debug",
                "Release",
                "RelWithDebInfo"
            ],
            "default": "Debug"
        },
        {
            "id": "platform",
            "type": "pickString",
            "description": "Select platform",
            "options": [
                "Win64",
                "Linux"
            ]
        },
        {
            "id": "tracy_enabled",
            "type": "pickString",
            "description": "Toggle tracy",
            "options": [
                "ON",
                "OFF"
            ],
            "default": "OFF"
        }
    ],
    "tasks": [
        {
            "label": "[CMake][Create]",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                ".",
                "-B Build_${input:platform}",
                "-DENABLE_TRACY=${input:tracy_enabled}",
                "-DCMAKE_BUILD_TYPE=${input:configuration}",
                "-DCMAKE_POLICY_VERSION_MINIMUM=3.5"
            ],
            "group": {
                "kind": "build",
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "revealProblems": "onProblem",
                "focus": true,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": true
            },
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "[CMake][Build][libCulTests]",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "Build_${input:platform}",
                "--config",
                "${input:configuration}",
                "-j16",
                "--target",
                "libculTests_static",
                "libculTests_dynamic"
            ],
            "group": {
                "kind": "build",
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "revealProblems": "onProblem",
                "focus": true,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": true
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "[CMake][Create]",
        },
        {
            "label": "[CMake][Build][All]",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "Build_${input:platform}",
                "--config",
                "${input:configuration}",
                "-j4"
            ],
            "group": {
                "kind": "build",
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "revealProblems": "onProblem",
                "focus": true,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": true
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "[CMake][Create]",
        },
        {
            "label": "[Win64][CMake][Create][CLang]",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                "..",
                "-G",
                "\"Visual Studio 17 2022\"",
                "..",
                "-B Build-Windows-CLang",
                "-T",
                "ClangCL",
                "-A",
                "x64"
            ],
            "group": {
                "kind": "build"
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "revealProblems": "onProblem",
                "focus": true,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": true
            },
            "options": {
                "cwd": "${workspaceFolder}/Build-Windows-CLang"
            }
        },
        {
            "label": "[Run][libculTets_static][Win64]",
            "type": "shell",
            "command": "${workspaceFolder}/Build_Win64/Debug/libculTests_static.exe",
            "options": {
                "cwd": "${workspaceFolder}/runDir"
            },
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": true
            }
        },
        {
            "label": "[Run][libculTets_dynamic][Win64]",
            "type": "shell",
            "command": "${workspaceFolder}/Build_Win64/Debug/libculTests_dynamic.exe",
            "options": {
                "cwd": "${workspaceFolder}/runDir"
            },
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": true
            }
        },
        {
            "label": "[Run][libculTets_static][Linux]",
            "type": "shell",
            "command": "${workspaceFolder}/Build_Linux/libculTests_static.bin",
            "options": {
                "cwd": "${workspaceFolder}/runDir"
            },
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": true
            }
        },
        {
            "label": "[Run][libculTets_dynamic][Linux]",
            "type": "shell",
            "command": "${workspaceFolder}/Build_Linux/libculTests_dynamic.bin",
            "options": {
                "cwd": "${workspaceFolder}/runDir"
            },
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": true
            }
        }
    ]
}